# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{cjs,js,json,jsonc,mjs,mts,ts,tsx,yml,yaml}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.rs]
indent_size = 4

[*.toml]
indent_size = 2

[Makefile]
indent_style = tab
